# --- LLM Provider (pick one) ---
# Default provider: azure, ollama, or anthropic
CHAT_PROVIDER=azure

# Azure OpenAI (required if CHAT_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
# AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Anthropic (required if CHAT_PROVIDER=anthropic, also used by hackathon-analyzer)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (required if CHAT_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=gpt-oss:20b

# --- Analyzer integration (all optional) ---

# Explicit path to the hackanalyze binary.
# Normally not needed — the app auto-detects it in this order:
#   1. This env var (if set)
#   2. 'hackanalyze' on system PATH (after `pip install -e .` in hackathon-analyzer/)
#   3. python -m hackathon_analyzer.cli via the sibling hackathon-analyzer/ folder
# HACKANALYZE_PATH=C:/path/to/hackanalyze

# Path to the hackathon-analyzer reports directory
# HACKANALYZE_REPORTS_DIR=./hackathon-analyzer/reports

# Path to the hackathon-analyzer repos directory (for clean command)
# HACKANALYZE_REPOS_DIR=./hackathon-analyzer/repos
