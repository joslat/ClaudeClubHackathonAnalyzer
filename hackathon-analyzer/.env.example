# GitHub Personal Access Token (required for plagiarism detection and repo size checks)
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo (for code search)
GITHUB_TOKEN=ghp_your_token_here

# Anthropic API Key (optional - enables AI-powered architecture summaries and plagiarism verdicts)
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- Optional overrides (defaults shown) ---

# Directory where repos are cloned
# REPOS_DIR=./repos

# Directory where reports are written
# REPORTS_DIR=./reports

# Directory for API response cache
# CACHE_DIR=./cache

# Max repo size in MB before skipping (safety limit)
# MAX_REPO_SIZE_MB=500

# Build timeout in seconds
# BUILD_TIMEOUT_SECONDS=120

# Clone timeout in seconds
# CLONE_TIMEOUT_SECONDS=300

# GitHub search cache TTL in seconds (default: 24 hours)
# CACHE_TTL_SECONDS=86400

# Claude model to use for AI analysis
# CLAUDE_MODEL=claude-opus-4-5

# Hackathon start date (ISO format) — used for freshness scoring
# HACKATHON_START_DATE=2026-03-01
